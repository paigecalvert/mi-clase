{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Mi Clase Helm Chart Values",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "resources": {
      "type": "object",
      "properties": {
        "requests": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        },
        "limits": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "host": { "type": "string" },
              "paths": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "path": { "type": "string" },
                    "pathType": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "tls": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "hosts": {
                "type": "array",
                "items": { "type": "string" }
              },
              "secretName": { "type": "string" }
            }
          }
        }
      }
    },
    "tls": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["", "auto", "manual", "selfsigned"],
          "description": "TLS mode: auto (cert-manager + Let's Encrypt), manual (BYO secret), selfsigned (cert-manager self-signed), or empty string to disable"
        },
        "secretName": { "type": "string" },
        "certManager": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "issuerKind": {
              "type": "string",
              "enum": ["ClusterIssuer", "Issuer"]
            },
            "issuerName": { "type": "string" },
            "email": { "type": "string" }
          }
        }
      }
    },
    "postgresql": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "auth": {
          "type": "object",
          "properties": {
            "database": { "type": "string" },
            "username": { "type": "string" },
            "password": { "type": "string" }
          }
        }
      }
    },
    "externalPostgresql": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "host": { "type": "string" },
        "port": { "type": ["integer", "string"] },
        "database": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" }
      }
    },
    "redis": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "architecture": {
          "type": "string",
          "enum": ["standalone", "replication"]
        },
        "auth": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "password": { "type": "string" }
          }
        }
      }
    },
    "externalRedis": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "host": { "type": "string" },
        "port": { "type": ["integer", "string"] },
        "password": { "type": "string" }
      }
    },
    "minio": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "rootUser": { "type": "string" },
        "rootPassword": { "type": "string" }
      }
    },
    "externalMinio": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "host": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "accessKey": { "type": "string" },
        "secretKey": { "type": "string" },
        "useSSL": { "type": "boolean" }
      }
    },
    "fileStorage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bucket": { "type": "string" }
      }
    },
    "certManager": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "install": { "type": "boolean" },
        "createIssuer": { "type": "boolean" },
        "crds": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        }
      }
    },
    "features": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "quizzesEnabled": { "type": "string" }
      }
    },
    "ingressController": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "cert-manager": {
      "type": "object"
    },
    "traefik": {
      "type": "object"
    },
    "global": {
      "type": "object"
    },
    "replicated": {
      "type": "object"
    },
    "libretranslate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          }
        },
        "externalUrl": { "type": "string" },
        "apiKey": { "type": "string" },
        "resources": {
          "type": "object",
          "properties": {
            "requests": {
              "type": "object",
              "properties": {
                "cpu": { "type": "string" },
                "memory": { "type": "string" }
              }
            },
            "limits": {
              "type": "object",
              "properties": {
                "cpu": { "type": "string" },
                "memory": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
