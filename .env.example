PORT=3000

# PostgreSQL
DATABASE_URL=postgresql://mi_clase:mi_clase@localhost:5432/mi_clase

# Redis
REDIS_URL=redis://localhost:6379

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=mi_clase
MINIO_SECRET_KEY=mi_clase_secret
MINIO_BUCKET=mi-clase
MINIO_USE_SSL=false

# LibreTranslate (self-hosted, runs via docker-compose)
LIBRE_TRANSLATE_URL=http://localhost:5000
# Only needed if using the managed libretranslate.com service instead of self-hosted
LIBRE_TRANSLATE_API_KEY=
