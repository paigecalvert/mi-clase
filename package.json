{
  "name": "mi-clase",
  "version": "1.0.0",
  "description": "Track notes, vocabulary, and homework from your Spanish classes",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "dev:local": "docker compose up -d && nodemon server/index.js",
    "build:client": "cd client && npm install && npm run build",
    "build": "npm run build:client"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-fileupload": "^1.5.0",
    "ioredis": "^5.3.2",
    "minio": "^8.0.1",
    "pg": "^8.11.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
